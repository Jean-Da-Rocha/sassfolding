{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 0.0.0.0",
    "lint": "eslint . --debug",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "vue-tsc": "vue-tsc --noEmit"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@internationalized/date": "~3.11.0",
    "@nuxt/ui": "^4.6.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "~7.0.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@iconify-json/lucide": "^1.2.101",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@unhead/vue": "^2.1.13",
    "@vue/runtime-core": "^3.5.32",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "eslint": "^9.39.2",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "husky": "^9.1.7",
    "hybridly": "0.10.0-beta.14",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.2.2",
    "taze": "^19.11.0",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "validate-branch-name": "^1.3.2",
    "vite": "^8.0.5",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "**/*.{vue,ts}": "eslint --fix",
    "**/*.php": "vendor/bin/pint"
  },
  "validate-branch-name": {
    "pattern": "^(build|bugfix|bump|docs|experimental|feature|hotfix|merge|refactor|release|test)(/[A-Z]+\\-\\d+)?/[a-z0-9]+(-[a-z0-9]+)*(?:-\\d+)?$",
    "errorMsg": "Incorrect branch name, please refer to the regex documentation -> https://extendsclass.com/regex/f92c0fc"
  }
}
